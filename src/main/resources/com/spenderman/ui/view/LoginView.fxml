<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.spenderman.ui.controller.ClsLoginController"
      styleClass="auth-container"
      alignment="CENTER"
      fillWidth="true">

    <!-- Header: Logo + subtitle (above the card) -->
    <VBox styleClass="auth-header" alignment="TOP_CENTER" spacing="4">
        <Label text="\$penderman" styleClass="app-logo"/>
        <Label text="Sign in to your account" styleClass="text-muted"/>
    </VBox>

    <VBox styleClass="auth-card" spacing="16" maxWidth="340">

        <!-- Welcome text -->
        <Label text="Welcome back" styleClass="page-title"/>

        <!-- Form fields -->
        <VBox spacing="10" styleClass="bg-transparent">
            <Label text="USERNAME" styleClass="field-label"/>
            <TextField fx:id="_usernameField" promptText="Your username"/>

            <Label text="PASSWORD" styleClass="field-label"/>
            <PasswordField fx:id="_passwordField" promptText="Your password"/>

            <!-- Error message (hidden by default) -->
            <Label fx:id="_errorLabel" styleClass="error-message"
                   visible="false" managed="false"/>
        </VBox>

        <!-- Sign In button -->
        <Button text="Sign In" styleClass="btn-primary-full"
                onAction="#_handleLogin" maxWidth="Infinity"/>

        <!-- Link to sign up -->
        <HBox alignment="CENTER" spacing="4">
            <padding><Insets top="14"/></padding>
            <Label text="No account?" styleClass="text-muted"/>
            <Hyperlink text="Create one" onAction="#_handleGoSignUp"/>
        </HBox>

    </VBox>
</VBox>
