<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.paint.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.spenderman.ui.controller.ClsCategoryController"
      spacing="12" styleClass="bg-root">
    <padding><Insets top="0" right="0" bottom="16" left="0"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Categories" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <Button text="+ New" styleClass="btn-small" onAction="#_toggleForm"/>
    </HBox>

    <!-- ═══ ADD CATEGORY FORM ═══ -->
    <VBox fx:id="_formPanel" styleClass="card-form" spacing="10" visible="false" managed="false">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="New Category" styleClass="section-title" HBox.hgrow="ALWAYS"/>
            <Button text="×" styleClass="btn-close" onAction="#_toggleForm"/>
        </HBox>
        <HBox spacing="10">
            <VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="bg-transparent">
                <Label text="NAME" styleClass="field-label"/>
                <TextField fx:id="_nameField" promptText='e.g. "Food"'/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="bg-transparent">
                <Label text="COLOR" styleClass="field-label"/>
                <ColorPicker fx:id="_colorPicker" maxWidth="Infinity" styleClass="color-picker-field"/>
            </VBox>
        </HBox>
        <VBox spacing="4" styleClass="bg-transparent">
            <Label text="TYPE" styleClass="field-label"/>
            <HBox spacing="6" styleClass="bg-transparent">
                <ToggleButton fx:id="_expenseToggle" text="Expense" styleClass="type-toggle-expense" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <ToggleButton fx:id="_depositToggle" text="Deposit" styleClass="type-toggle-deposit" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
        </VBox>
        <HBox spacing="8" alignment="CENTER_RIGHT">
            <Button text="Cancel" styleClass="btn-outline" onAction="#_toggleForm"/>
            <Button text="Create Category" styleClass="btn-primary" onAction="#_handleAddCategory"/>
        </HBox>
    </VBox>

    <!-- ═══ CATEGORY GRID ═══ -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
        <GridPane fx:id="_categoryGrid" hgap="10" vgap="10"/>
    </ScrollPane>
</VBox>
