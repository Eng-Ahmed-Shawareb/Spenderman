<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.spenderman.ui.controller.AppShellController"
      styleClass="bg-root"
      fillHeight="true">

    <!-- ═══ SIDEBAR ═══ -->
    <VBox styleClass="sidebar" fillWidth="true">

        <!-- Logo section -->
        <VBox styleClass="sidebar-logo" spacing="2">
            <Label text="\$penderman" styleClass="app-logo-sidebar"/>
            <Label text="Personal Finance" styleClass="text-muted"/>
        </VBox>

        <!-- Navigation buttons -->
        <VBox fx:id="navBox" styleClass="sidebar-nav" VBox.vgrow="ALWAYS" fillWidth="true">
            <Button fx:id="navDashboard"    text="⊞ Dashboard"    styleClass="nav-button" onAction="#navToDashboard"    maxWidth="Infinity"/>
            <Button fx:id="navTransactions" text="↕ Transactions" styleClass="nav-button" onAction="#navToTransactions" maxWidth="Infinity"/>
            <Button fx:id="navWallets"      text="◈ Wallets"      styleClass="nav-button" onAction="#navToWallets"      maxWidth="Infinity"/>
            <Button fx:id="navCategories"   text="◉ Categories"   styleClass="nav-button" onAction="#navToCategories"   maxWidth="Infinity"/>
            <Button fx:id="navCycles"       text="◎ Cycles"       styleClass="nav-button" onAction="#navToCycles"       maxWidth="Infinity"/>
            <Button fx:id="navGoals"        text="◇ Goals"        styleClass="nav-button" onAction="#navToGoals"        maxWidth="Infinity"/>
            <Button fx:id="navSettings"     text="⚙ Settings"     styleClass="nav-button" onAction="#navToSettings"     maxWidth="Infinity"/>
        </VBox>

        <!-- User profile footer -->
        <HBox styleClass="sidebar-footer" spacing="8" alignment="CENTER_LEFT">
            <StackPane prefWidth="28" prefHeight="28">
                <javafx.scene.shape.Circle radius="14" styleClass="avatar-circle"/>
                <Label fx:id="avatarInitials" text="AH" styleClass="avatar-initials"/>
            </StackPane>
            <VBox spacing="1" styleClass="bg-transparent">
                <Label fx:id="userNameLabel" text="Ahmed" styleClass="text-primary" style="-fx-font-size: 11px;"/>
                <Label text="🌙 Dark Mode" styleClass="text-muted" style="-fx-font-size: 9px;"/>
            </VBox>
        </HBox>

    </VBox>

    <!-- ═══ CONTENT AREA ═══ -->
    <StackPane fx:id="contentArea" styleClass="content-area" HBox.hgrow="ALWAYS">
        <!-- Content screens will be loaded here dynamically -->
    </StackPane>

</HBox>
