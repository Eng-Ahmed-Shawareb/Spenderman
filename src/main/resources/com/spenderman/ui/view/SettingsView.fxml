<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spenderman.ui.controller.SettingsController"
            fitToWidth="true" fitToHeight="true"
            styleClass="scroll-pane">

    <VBox spacing="14" styleClass="bg-root">
        <padding><Insets top="0" right="0" bottom="16" left="0"/></padding>

        <!-- Page Title -->
        <Label text="Settings" styleClass="page-title"/>

        <!-- ═══ PROFILE CARD ═══ -->
        <HBox styleClass="card" spacing="14" alignment="CENTER_LEFT">
            <StackPane prefWidth="44" prefHeight="44">
                <javafx.scene.shape.Circle radius="22" styleClass="profile-avatar"/>
                <Label fx:id="profileInitials" text="AH" styleClass="avatar-initials" style="-fx-font-size: 14px;"/>
            </StackPane>
            <VBox spacing="2" styleClass="bg-transparent">
                <Label fx:id="profileNameLabel" text="Ahmed Hassan" styleClass="section-title" style="-fx-font-size: 14px;"/>
                <Label fx:id="profileSubLabel" text="@ahmed · Member since Jan 2025" styleClass="text-muted"/>
            </VBox>
        </HBox>

        <!-- ═══ SETTINGS CARD ═══ -->
        <VBox styleClass="card-large" spacing="0">

            <!-- APPEARANCE SECTION -->
            <VBox spacing="10" styleClass="bg-transparent">
                <Label text="APPEARANCE" styleClass="field-label"/>
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="2" styleClass="bg-transparent" HBox.hgrow="ALWAYS">
                        <Label text="Interface Theme" styleClass="section-title"/>
                        <Label fx:id="themeStatusLabel" text="Currently: Dark Mode" styleClass="text-muted"/>
                    </VBox>
                    <HBox spacing="8" alignment="CENTER">
                        <Label text="☀" styleClass="text-amber" style="-fx-font-size: 11px;"/>
                        <ToggleButton fx:id="themeToggle" selected="true" onAction="#handleThemeToggle"/>
                        <Label text="☽" styleClass="text-blue" style="-fx-font-size: 11px;"/>
                    </HBox>
                </HBox>
            </VBox>

            <Separator/>

            <!-- SECURITY SECTION -->
            <VBox spacing="10" styleClass="bg-transparent">
                <Label text="SECURITY" styleClass="field-label"/>
                <VBox spacing="4" styleClass="bg-transparent">
                    <Label text="CURRENT PASSWORD" styleClass="field-label"/>
                    <PasswordField fx:id="oldPasswordField" promptText="Enter current password"/>
                </VBox>
                <HBox spacing="10">
                    <VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="bg-transparent">
                        <Label text="NEW PASSWORD" styleClass="field-label"/>
                        <PasswordField fx:id="newPasswordField" promptText="Min 6 characters"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="bg-transparent">
                        <Label text="CONFIRM NEW PASSWORD" styleClass="field-label"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="Repeat new password"/>
                    </VBox>
                </HBox>
                <Label fx:id="passwordFeedback" styleClass="text-muted" visible="false" managed="false" style="-fx-font-size: 10px;"/>
                <Button text="Update Password" styleClass="btn-primary-full" onAction="#handleChangePassword" maxWidth="Infinity"/>
            </VBox>

            <Separator/>

            <!-- SESSION SECTION -->
            <VBox spacing="10" styleClass="bg-transparent">
                <Label text="SESSION" styleClass="field-label"/>
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="2" styleClass="bg-transparent" HBox.hgrow="ALWAYS">
                        <Label text="Sign Out" styleClass="section-title"/>
                        <Label text="You will be returned to the login screen" styleClass="text-muted"/>
                    </VBox>
                    <Button text="Logout" styleClass="btn-danger" onAction="#handleLogout"/>
                </HBox>
            </VBox>

        </VBox>
    </VBox>
</ScrollPane>
