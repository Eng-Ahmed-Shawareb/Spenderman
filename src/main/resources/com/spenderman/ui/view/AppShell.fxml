<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.spenderman.ui.controller.ClsAppShellController"
      styleClass="bg-root"
      fillHeight="true">

    <VBox styleClass="sidebar" fillWidth="true">

        <VBox styleClass="sidebar-logo" spacing="6">
            <ImageView fx:id="_sidebarLogo" fitWidth="24" fitHeight="24" pickOnBounds="true" preserveRatio="true">
                <Image url="@../../../../utils/darkmodeicon.png"/>
            </ImageView>
            <VBox spacing="0">
                <Label text="\$penderman" styleClass="app-logo-sidebar"/>
                <Label text="Personal Finance" styleClass="text-muted" style="-fx-font-size: 11px;"/>
            </VBox>
        </VBox>

        <VBox fx:id="_navBox" styleClass="sidebar-nav" VBox.vgrow="ALWAYS" fillWidth="true">
            <Button fx:id="_navDashboard"    text="⊞ Dashboard"    styleClass="nav-button" onAction="#_navToDashboard"    maxWidth="Infinity"/>
            <Button fx:id="_navTransactions" text="↕ Transactions" styleClass="nav-button" onAction="#_navToTransactions" maxWidth="Infinity"/>
            <Button fx:id="_navWallets"      text="◈ Wallets"      styleClass="nav-button" onAction="#_navToWallets"      maxWidth="Infinity"/>
            <Button fx:id="_navCategories"   text="◉ Categories"   styleClass="nav-button" onAction="#_navToCategories"   maxWidth="Infinity"/>
            <Button fx:id="_navCycles"       text="◎ Cycles"       styleClass="nav-button" onAction="#_navToCycles"       maxWidth="Infinity"/>
            <Button fx:id="_navGoals"        text="◇ Goals"        styleClass="nav-button" onAction="#_navToGoals"        maxWidth="Infinity"/>

            <Button fx:id="_navAiChat"       text="✨ AI Chat"      styleClass="nav-button" onAction="#_onAiChatClick"     maxWidth="Infinity"/>

            <Button fx:id="_navSettings"     text="⚙ Settings"     styleClass="nav-button" onAction="#_navToSettings"     maxWidth="Infinity"/>
        </VBox>

        <HBox styleClass="sidebar-footer" spacing="8" alignment="CENTER_LEFT">
            <StackPane prefWidth="28" prefHeight="28">
                <javafx.scene.shape.Circle radius="14" styleClass="avatar-circle"/>
                <Label fx:id="_avatarInitials" text="AH" styleClass="avatar-initials"/>
            </StackPane>
            <VBox spacing="1" styleClass="bg-transparent">
                <Label fx:id="_userNameLabel" text="Ahmed" styleClass="text-primary" style="-fx-font-size: 13px;"/>
            </VBox>
        </HBox>

    </VBox>

    <StackPane fx:id="_contentArea" styleClass="content-area" HBox.hgrow="ALWAYS">
    </StackPane>

</HBox>