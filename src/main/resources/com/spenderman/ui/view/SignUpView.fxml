<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.spenderman.ui.controller.ClsSignUpController"
      styleClass="auth-container"
      alignment="CENTER"
      fillWidth="true">

    <!-- Header: Logo + subtitle (above the card) -->
    <VBox styleClass="auth-header" alignment="TOP_CENTER" spacing="4">
        <Label text="\$penderman" styleClass="app-logo"/>
        <Label text="Create your account" styleClass="text-muted"/>
    </VBox>

    <VBox styleClass="auth-card" spacing="16" maxWidth="360">

        <!-- Title -->
        <Label text="Create account" styleClass="page-title"/>

        <!-- Form fields -->
        <VBox spacing="10" styleClass="bg-transparent">
            <!-- Name row (2 columns) -->
            <HBox spacing="10" styleClass="bg-transparent">
                <VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="bg-transparent">
                    <Label text="FIRST NAME" styleClass="field-label"/>
                    <TextField fx:id="_firstNameField" promptText="Ahmed"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="bg-transparent">
                    <Label text="LAST NAME" styleClass="field-label"/>
                    <TextField fx:id="_lastNameField" promptText="Hassan"/>
                </VBox>
            </HBox>

            <Label text="USERNAME" styleClass="field-label"/>
            <TextField fx:id="_usernameField" promptText="Choose a username"/>

            <Label text="PASSWORD" styleClass="field-label"/>
            <PasswordField fx:id="_passwordField" promptText="Min 6 characters"/>

            <!-- Error message (hidden by default) -->
            <Label fx:id="_errorLabel" styleClass="error-message"
                   visible="false" managed="false"/>

            <!-- Success message (hidden by default) -->
            <Label fx:id="_successLabel" styleClass="success-message"
                   visible="false" managed="false"/>
        </VBox>

        <!-- Create Account button -->
        <Button text="Create Account" styleClass="btn-primary-full"
                onAction="#_handleSignUp" maxWidth="Infinity"/>

        <!-- Link to login -->
        <HBox alignment="CENTER" spacing="4">
            <padding><Insets top="14"/></padding>
            <Label text="Already have an account?" styleClass="text-muted"/>
            <Hyperlink text="Sign in" onAction="#_handleGoLogin"/>
        </HBox>

    </VBox>
</VBox>
